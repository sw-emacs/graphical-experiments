;;; pb-demo-init.el --- Loader and help for PB Emacs demos -*- lexical-binding: t; -*-

(require 'pb-menu)
(require 'pb-chart)
(require 'pb-media)
(require 'pb-web)
(require 'pb-present)

(defun pb-demo-help ()
  "Open a buffer describing the available demo commands."
  (interactive)
  (let ((buf (get-buffer-create "*PB Demo Help*"))
        (inhibit-read-only t))
    (with-current-buffer buf
      (erase-buffer)
      (special-mode)
      (insert "PB Emacs Demo Commands\n\n")
      (insert "Load:\n")
      (insert "  (add-to-list 'load-path \"/path/to/pb-emacs-demo\")\n")
      (insert "  (require 'pb-demo-init)\n\n")
      (insert "Commands:\n")
      (insert "  M-x pb-menu-demo\n")
      (insert "  M-x pb-menu-illuminated-demo\n")
      (insert "  M-x pb-chart-bar-demo\n")
      (insert "  M-x pb-chart-sparkline-demo\n")
      (insert "  M-x pb-chart-scatter-demo\n")
      (insert "  M-x pb-media-open-image\n")
      (insert "  M-x pb-media-header-heat-start\n")
      (insert "  M-x pb-media-header-heat-stop\n")
      (insert "  M-x pb-present-demo\n")
      (insert "  M-x pb-web-status\n")
      (insert "  M-x pb-web-browse-url\n")
      (insert "  M-x pb-web-open-local-file\n\n")
      (insert "Presentation keys:\n")
      (insert "  n next slide\n")
      (insert "  p previous slide\n")
      (insert "  g redraw\n")
      (insert "  q quit window\n\n")
      (insert "Notes:\n")
      (insert "  SVG demos require SVG support in your Emacs build.\n")
      (insert "  xwidgets are optional. EAF is optional.\n")
      (goto-char (point-min)))
    (pop-to-buffer buf)))

(provide 'pb-demo-init)
;;; pb-demo-init.el ends here
